# Supabase server-side credentials.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Google Drive service account JSON can be the full JSON string or a path to a JSON file.
GDRIVE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace-me"}
GDRIVE_INVENTORY_FILE_ID=replace-with-drive-inventory-file-id

# Worker behavior.
ML_JOB_TABLE=v2_ml_image_jobs
ML_PHOTO_BUCKET=ml_capture_photos
ML_TRAINING_ASSETS_TABLE=v2_disease_training_assets
ML_TRAINING_ASSETS_BUCKET=disease_training_assets
APP_LIVE_EVENTS_TABLE=v2_app_live_events
GROWER_SCOUT_REPORTS_TABLE=v2_grower_scout_reports
GROWER_SCOUT_ASSETS_TABLE=v2_grower_scout_assets
GROWER_SCOUT_AUDIO_BUCKET=grower_scout_audio
GROWER_SCOUT_PHOTOS_BUCKET=grower_scout_photos
GROWER_SCOUT_FILES_BUCKET=grower_scout_files
OLLAMA_URL=http://localhost:11434
SCOUT_SUMMARY_MODEL=qwen2.5:3b-instruct
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
PUSH_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1/send-push-alert
PEST_MANAGEMENT_ALERT_USERNAMES=dylan_collyge
ML_POLL_SECONDS=10
ML_BATCH_SIZE=3
ML_STALE_PROCESSING_MINUTES=30
ML_INVENTORY_REFRESH_SECONDS=900

# Model files synced into ./models by GitHub Actions.
ML_MODELS_DIR=/app/models
ML_MODEL_PATH=/app/models/plant_classifier.pt
ML_LABELS_PATH=/app/models/labels.json
ML_DIAGNOSTICS_MODEL_PATH=
ML_DIAGNOSTICS_LABELS_PATH=
DIAGNOSTICS_TRAIN_EPOCHS=8
DIAGNOSTICS_TRAIN_BATCH_SIZE=12
DIAGNOSTICS_EXTRACT_PDF_IMAGES=true
DIAGNOSTICS_USE_PRETRAINED=true
ML_CONFIDENCE_THRESHOLD=0.62

LOG_LEVEL=INFO
